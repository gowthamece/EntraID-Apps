<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Error</title>
</head>
<body>
    <h1>Error</h1>
    <h2>An error occurred while processing your request.</h2>
    @if (!string.IsNullOrWhiteSpace(ViewBag.ErrorMessage as string))
    {
        <p>@ViewBag.ErrorMessage</p>
    }
</body>
</html>
