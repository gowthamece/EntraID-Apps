@page "/function-ping"
@attribute [Authorize]
@rendermode InteractiveServer
@inject FunctionApiService FunctionApiService

<PageTitle>Function Ping</PageTitle>

<h1>Function Auth Ping</h1>

<p>Calls the secured endpoint using Microsoft Entra token from managed identity.</p>

<button class="btn btn-primary" @onclick="CallPingAsync" disabled="@_isLoading">
    @(_isLoading ? "Calling..." : "Call /api/auth/ping")
</button>

@if (_result is not null)
{
    <div class="mt-3">
        <p><strong>Success:</strong> @_result.Success</p>
        <p><strong>Status:</strong> @(_result.StatusCode?.ToString() ?? "n/a")</p>
        <p><strong>Token Expires:</strong> @(_result.TokenExpiresOn?.ToString("u") ?? "n/a")</p>

        @if (!string.IsNullOrWhiteSpace(_result.ErrorMessage))
        {
            <p><strong>Error:</strong> @_result.ErrorMessage</p>
        }

        @if (!string.IsNullOrWhiteSpace(_result.ResponseBody))
        {
            <h3>Response Body</h3>
            <pre>@_result.ResponseBody</pre>
        }
    </div>
}

@code {
    private bool _isLoading;
    private FunctionPingResult? _result;

    private async Task CallPingAsync()
    {
        _isLoading = true;
        try
        {
            _result = await FunctionApiService.GetAuthenticatedPingAsync();
        }
        finally
        {
            _isLoading = false;
        }
    }
}
